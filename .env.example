# ─────────────────────────────────────────────────────────────
# Schema Studio — Environment Variables
# Copy this file to .env and fill in the values.
# None of these are required to run the app locally.
# They are only needed when using the Migrations workflow
# to connect to a live database.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Used by: Migrations → Collect, Validate, Run
# Example: postgresql://user:password@localhost:5432/mydb
POSTGRES_URL=

# MySQL connection string
# Used by: Migrations → Collect, Validate, Run
# Example: mysql://user:password@localhost:3306/mydb
MYSQL_URL=
