    "prisma": "^6.19.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/pg": "^8.11.13",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3"
  }
}
