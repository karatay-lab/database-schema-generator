generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id            String @id @default(uuid())
  name          String @unique
  provider      String
  schemaOptions String @map("schema_options")
  health        String @default("Draft")
  tables        Int    @default(0)
  fields        Int    @default(0)
  relations     Int    @default(0)
  restrictions  Int    @default(0)

  projectVersions        ProjectVersion[]        @relation("ProjectVersions")
  modelStores            ModelStore[]            @relation("ProjectModelStores")
  schemaTables           SchemaTable[]           @relation("ProjectTables")
  fsPaths                FsPath[]                @relation("ProjectFsPaths")
  migrationWorkflowState MigrationWorkflowState? @relation("ProjectWorkflowState")
  schemaArtifacts        SchemaArtifact[]        @relation("ProjectArtifacts")
  migrationConnections   MigrationConnection[]   @relation("ProjectConnections")
  schemaImports          SchemaImport[]          @relation("ProjectImports")
  migrationSnapshots     MigrationSnapshot[]     @relation("ProjectSnapshots")
  migrationSessions      MigrationSession[]      @relation("ProjectMigrationSessions")
  pipelineSnapshots      PipelineSnapshot[]      @relation("ProjectPipelineSnapshots")
  pipelineRuns           PipelineRun[]           @relation("ProjectPipelineRuns")

  @@map("projects")
}

model ProjectVersion {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  name      String
  major     Int    @default(1)
  minor     Int    @default(111)
  createdAt String @map("created_at")
  sortOrder Int    @default(0) @map("sort_order")

  project         Project          @relation("ProjectVersions", fields: [projectId], references: [id], onDelete: Cascade)
  schemaTables    SchemaTable[]    @relation("VersionTables")
  schemaRelations SchemaRelation[] @relation("VersionRelations")
  schemaEnums     SchemaEnum[]     @relation("VersionEnums")
  schemaArtifacts SchemaArtifact[] @relation("VersionArtifacts")

  @@unique([projectId, name])
  @@unique([projectId, major, minor])
  @@map("project_versions")
}

model ModelStore {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  version   String
  content   String
  updatedAt String @map("updated_at")

  project Project @relation("ProjectModelStores", fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@map("model_stores")
}

model SchemaTable {
  id        String  @id @default(uuid())
  modelKey  String  @default("") @map("model_key")
  tableId   String  @default("") @map("table_id")
  projectId String  @map("project_id")
  versionId String  @map("version_id")
  name      String
  dbName    String? @map("db_name")
  comment   String  @default("")
  sortOrder Int     @default(0) @map("sort_order")
  createdAt String  @map("created_at")
  updatedAt String  @map("updated_at")

  project         Project              @relation("ProjectTables", fields: [projectId], references: [id], onDelete: Cascade)
  version         ProjectVersion       @relation("VersionTables", fields: [versionId], references: [id], onDelete: Cascade)
  schemaFields    SchemaField[]        @relation("TableFields")
  constraints     SchemaConstraint[]   @relation("TableConstraints")
  sourceRelations SchemaRelation[]     @relation("SourceTableRelations")
  targetRelations SchemaRelation[]     @relation("TargetTableRelations")
  relationSides   SchemaRelationSide[] @relation("TableRelationSides")

  @@unique([versionId, name])
  @@map("schema_tables")
}

model SchemaField {
  id              String  @id @default(uuid())
  fieldKey        String  @default("") @map("field_key")
  fieldId         String  @default("") @map("field_id")
  tableId         String  @map("table_id")
  name            String
  dbName          String? @map("db_name")
  logicalType     String  @map("logical_type")
  nativeType      String? @map("native_type")
  nullable        Boolean @default(false)
  isArray         Boolean @default(false) @map("is_array")
  defaultKind     String  @default("none") @map("default_kind")
  defaultValue    String  @default("") @map("default_value")
  defaultPostgres String? @map("default_postgres")
  defaultMysql    String? @map("default_mysql")
  defaultSqlite   String? @map("default_sqlite")
  comment         String  @default("")
  isId        Boolean @default(false) @map("is_id")
  isUpdatedAt     Boolean @default(false) @map("is_updated_at")
  sortOrder       Int     @default(0) @map("sort_order")
  createdAt       String  @map("created_at")
  updatedAt       String  @map("updated_at")

  table                SchemaTable             @relation("TableFields", fields: [tableId], references: [id], onDelete: Cascade)
  constraintFields     SchemaConstraintField[] @relation("FieldConstraintMembers")
  sourceRelationFields SchemaRelationField[]   @relation("SourceFieldMappings")
  targetRelationFields SchemaRelationField[]   @relation("TargetFieldMappings")

  @@unique([tableId, name])
  @@map("schema_fields")
}

model SchemaConstraint {
  id            String  @id @default(uuid())
  restrictionId String  @default("") @map("restriction_id")
  tableId       String  @map("table_id")
  type          String
  name          String?
  dbName        String? @map("db_name")
  createdAt     String  @map("created_at")
  updatedAt     String  @map("updated_at")

  table            SchemaTable             @relation("TableConstraints", fields: [tableId], references: [id], onDelete: Cascade)
  constraintFields SchemaConstraintField[] @relation("ConstraintFieldMembers")

  @@map("schema_constraints")
}

model SchemaConstraintField {
  constraintId String @map("constraint_id")
  fieldId      String @map("field_id")
  sortOrder    Int    @default(0) @map("sort_order")

  constraint SchemaConstraint @relation("ConstraintFieldMembers", fields: [constraintId], references: [id], onDelete: Cascade)
  field      SchemaField      @relation("FieldConstraintMembers", fields: [fieldId], references: [id], onDelete: Cascade)

  @@id([constraintId, fieldId])
  @@map("schema_constraint_fields")
}

model SchemaRelation {
  id            String @id @default(uuid())
  relationId    String @default("") @map("relation_id")
  versionId     String @map("version_id")
  name          String
  sourceTableId String @map("source_table_id")
  targetTableId String @map("target_table_id")
  cardinality   String @default("many-to-one")
  onDelete      String @default("") @map("on_delete")
  onUpdate      String @default("") @map("on_update")
  createdAt     String @map("created_at")
  updatedAt     String @map("updated_at")

  version        ProjectVersion        @relation("VersionRelations", fields: [versionId], references: [id], onDelete: Cascade)
  sourceTable    SchemaTable           @relation("SourceTableRelations", fields: [sourceTableId], references: [id], onDelete: Cascade)
  targetTable    SchemaTable           @relation("TargetTableRelations", fields: [targetTableId], references: [id], onDelete: Cascade)
  relationFields SchemaRelationField[] @relation("RelationFieldMappings")
  relationSides  SchemaRelationSide[]  @relation("RelationSides")

  @@unique([versionId, name])
  @@map("schema_relations")
}

model SchemaRelationField {
  relationId    String @map("relation_id")
  sourceFieldId String @map("source_field_id")
  targetFieldId String @map("target_field_id")
  sortOrder     Int    @default(0) @map("sort_order")

  relation    SchemaRelation @relation("RelationFieldMappings", fields: [relationId], references: [id], onDelete: Cascade)
  sourceField SchemaField    @relation("SourceFieldMappings", fields: [sourceFieldId], references: [id], onDelete: Cascade)
  targetField SchemaField    @relation("TargetFieldMappings", fields: [targetFieldId], references: [id], onDelete: Cascade)

  @@id([relationId, sourceFieldId, targetFieldId])
  @@map("schema_relation_fields")
}

model SchemaRelationSide {
  id         String  @id @default(uuid())
  relationId String  @map("relation_id")
  tableId    String  @map("table_id")
  fieldName  String  @map("field_name")
  isOwner    Boolean @default(false) @map("is_owner")
  isList     Boolean @default(false) @map("is_list")
  nullable   Boolean @default(false)
  createdAt  String  @map("created_at")
  updatedAt  String  @map("updated_at")

  relation SchemaRelation @relation("RelationSides", fields: [relationId], references: [id], onDelete: Cascade)
  table    SchemaTable    @relation("TableRelationSides", fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([relationId, tableId, isOwner])
  @@map("schema_relation_sides")
}

model SchemaEnum {
  id        String  @id @default(uuid())
  versionId String  @map("version_id")
  name      String
  dbName    String? @map("db_name")
  sortOrder Int     @default(0) @map("sort_order")
  createdAt String  @map("created_at")
  updatedAt String  @map("updated_at")

  version    ProjectVersion    @relation("VersionEnums", fields: [versionId], references: [id], onDelete: Cascade)
  enumValues SchemaEnumValue[] @relation("EnumValues")

  @@unique([versionId, name])
  @@map("schema_enums")
}

model SchemaEnumValue {
  id        String  @id @default(uuid())
  enumId    String  @map("enum_id")
  name      String
  dbName    String? @map("db_name")
  sortOrder Int     @default(0) @map("sort_order")
  createdAt String  @map("created_at")
  updatedAt String  @map("updated_at")

  enum SchemaEnum @relation("EnumValues", fields: [enumId], references: [id], onDelete: Cascade)

  @@unique([enumId, name])
  @@map("schema_enum_values")
}

model FieldTemplate {
  id                 String  @id @default(uuid())
  name               String  @unique
  type               String
  nullable           Boolean @default(false)
  uniqueField        Boolean @default(false) @map("unique_field")
  defaultValue       String  @default("") @map("default_value")
  comment            String  @default("")
  nativeAttribute    String? @map("native_attribute")
  updatedAtAttribute Boolean @default(false) @map("updated_at_attribute")
  isId               Boolean @default(false) @map("is_id")
  createdAt          String  @map("created_at")
  updatedAt          String  @map("updated_at")

  @@map("field_templates")
}

model FsPath {
  id           String  @id @default(uuid())
  projectId    String? @map("project_id")
  connectionId String? @map("connection_id")
  version      String?
  fileType     String  @map("file_type")
  label        String?
  fsPath       String  @unique @map("fs_path")
  createdAt    String  @map("created_at")

  project Project? @relation("ProjectFsPaths", fields: [projectId], references: [id], onDelete: Cascade)

  @@map("fs_paths")
}

model UiState {
  key       String @id
  value     String
  updatedAt String @map("updated_at")

  @@map("ui_state")
}

model MigrationWorkflowState {
  projectId         String  @id @map("project_id")
  connectionId      String? @map("connection_id")
  syncVersion       String? @map("sync_version")
  targetVersion     String? @map("target_version")
  dataTimestamp     String? @map("data_timestamp")
  snapshotId        String? @map("snapshot_id")
  zodGenerated      Boolean @default(false) @map("zod_generated")
  schemaCheckPassed Boolean @default(false) @map("schema_check_passed")
  validationPassed  Boolean @default(false) @map("validation_passed")
  runLogPath        String? @map("run_log_path")
  updatedAt         String  @map("updated_at")

  project  Project            @relation("ProjectWorkflowState", fields: [projectId], references: [id], onDelete: Cascade)
  snapshot MigrationSnapshot? @relation("WorkflowStateSnapshot", fields: [snapshotId], references: [id], onDelete: SetNull)

  @@map("migration_workflow_state")
}

model SchemaArtifact {
  id          String  @id @default(uuid())
  projectId   String  @map("project_id")
  versionId   String? @map("version_id")
  type        String
  fsPath      String  @map("fs_path")
  contentHash String? @map("content_hash")
  compressed  Boolean @default(false)
  encrypted   Boolean @default(false)
  temporary   Boolean @default(true)
  expiresAt   String? @map("expires_at")
  createdAt   String  @map("created_at")

  project Project         @relation("ProjectArtifacts", fields: [projectId], references: [id], onDelete: Cascade)
  version ProjectVersion? @relation("VersionArtifacts", fields: [versionId], references: [id], onDelete: Cascade)

  @@map("schema_artifacts")
}

model MigrationConnection {
  id          String @id @default(uuid())
  projectId   String @map("project_id")
  nameEnc     String @default("") @map("name_enc")
  providerEnc String @default("") @map("provider_enc")
  hostEnc     String @default("") @map("host_enc")
  portEnc     String @default("") @map("port_enc")
  databaseEnc String @default("") @map("database_enc")
  userEnc     String @default("") @map("user_enc")
  passwordEnc String @default("") @map("password_enc")
  secret      String @default("")
  createdAt   String @map("created_at")
  lastUsedAt  String @map("last_used_at")

  project Project @relation("ProjectConnections", fields: [projectId], references: [id], onDelete: Cascade)

  @@map("migration_connections")
}

model SchemaImport {
  id         String  @id @default(uuid())
  projectId  String? @map("project_id")
  version    String?
  sourceFile String  @map("source_file")
  importedAt String  @map("imported_at")

  project Project? @relation("ProjectImports", fields: [projectId], references: [id], onDelete: Cascade)

  @@map("schema_imports")
}

model MigrationSnapshot {
  id           String @id @default(uuid())
  projectId    String @map("project_id")
  connectionId String @map("connection_id")
  fromVersion  String @map("from_version")
  toVersion    String @map("to_version")
  folderPath   String @unique @map("folder_path")
  tableCount   Int    @default(0) @map("table_count")
  rowCount     Int    @default(0) @map("row_count")
  tablesJson   String @default("[]") @map("tables_json")
  collectedAt  String @map("collected_at")

  project                Project                  @relation("ProjectSnapshots", fields: [projectId], references: [id], onDelete: Cascade)
  migrationWorkflowState MigrationWorkflowState[] @relation("WorkflowStateSnapshot")
  migrationSessions      MigrationSession[]       @relation("SnapshotSessions")

  @@map("migration_snapshots")
}

model MigrationSession {
  id                String  @id @default(uuid())
  projectId         String  @map("project_id")
  connectionId      String  @map("connection_id")
  fromVersion       String  @map("from_version")
  toVersion         String  @map("to_version")
  snapshotId        String? @map("snapshot_id")
  collectTimestamp  String? @map("collect_timestamp")
  collectTableCount Int?    @map("collect_table_count")
  collectRowCount   Int?    @map("collect_row_count")
  collectTablesJson String? @map("collect_tables_json")
  runStatus         String? @map("run_status")
  runLogPath        String? @map("run_log_path")
  runTablesJson     String? @map("run_tables_json")
  runError          String? @map("run_error")
  createdAt         String  @map("created_at")
  updatedAt         String  @map("updated_at")

  project  Project            @relation("ProjectMigrationSessions", fields: [projectId], references: [id], onDelete: Cascade)
  snapshot MigrationSnapshot? @relation("SnapshotSessions", fields: [snapshotId], references: [id], onDelete: SetNull)

  @@unique([projectId, fromVersion, toVersion, connectionId])
  @@map("migration_sessions")
}

model PipelineSnapshot {
  id          String @id @default(uuid())
  projectId   String @map("project_id")
  projectName String @map("project_name")
  versionId   String @map("version_id")
  versionName String @map("version_name")
  syncVersion String @map("sync_version")
  folderPath  String @unique @map("folder_path")
  folderHash  String @map("folder_hash")
  tableCount  Int    @default(0) @map("table_count")
  rowCount    Int    @default(0) @map("row_count")
  tablesJson  String @default("[]") @map("tables_json")
  collectedAt String @map("collected_at")
  createdAt   String @map("created_at")

  project     Project              @relation("ProjectPipelineSnapshots", fields: [projectId], references: [id], onDelete: Cascade)
  validations PipelineValidation[] @relation("SnapshotValidations")
  runs        PipelineRun[]        @relation("SnapshotRuns")

  @@map("pipeline_snapshots")
}

model PipelineValidation {
  id             String  @id @default(uuid())
  snapshotId     String  @map("snapshot_id")
  projectId      String  @map("project_id")
  projectName    String  @map("project_name")
  syncVersion    String  @map("sync_version")
  targetVersion  String  @map("target_version")
  stage1Json     String  @map("stage1_json")
  stage2Json     String  @map("stage2_json")
  blockingErrors Int     @map("blocking_errors")
  passed         Boolean
  validatedAt    String  @map("validated_at")

  snapshot PipelineSnapshot @relation("SnapshotValidations", fields: [snapshotId], references: [id], onDelete: Cascade)
  run      PipelineRun?     @relation("ValidationRun")

  @@map("pipeline_validations")
}

model PipelineRun {
  id            String  @id @default(uuid())
  snapshotId    String  @map("snapshot_id")
  validationId  String  @unique @map("validation_id")
  projectId     String  @map("project_id")
  projectName   String  @map("project_name")
  syncVersion   String  @map("sync_version")
  targetVersion String  @map("target_version")
  tableCount    Int     @default(0) @map("table_count")
  rowCount      Int     @default(0) @map("row_count")
  tablesJson    String  @default("[]") @map("tables_json")
  passed        Boolean
  ranAt         String  @map("ran_at")

  project    Project            @relation("ProjectPipelineRuns",  fields: [projectId],    references: [id], onDelete: Cascade)
  snapshot   PipelineSnapshot   @relation("SnapshotRuns",         fields: [snapshotId],   references: [id], onDelete: Cascade)
  validation PipelineValidation @relation("ValidationRun",        fields: [validationId], references: [id], onDelete: Cascade)

  @@map("pipeline_runs")
}
