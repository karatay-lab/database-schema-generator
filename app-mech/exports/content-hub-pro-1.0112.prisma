// Content Hub Pro 1.0112 Prisma schema
// Generated from app-mech database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Author {
  /// Content creator with public profile, bio, and avatar
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Author full display name
  name String @db.VarChar(150)
  /// Unique login and contact email
  email String @db.VarChar(255)
  /// Short editorial biography shown on author pages
  biography String? @db.Text
  /// URL to the author profile image
  avatarUrl String? @db.VarChar(500) @map("avatar_url")
  /// Whether the author can publish new content
  isActive Boolean @default(true) @map("is_active")
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  /// Record last-modified timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  media Media[] @relation("MediaToAuthor")
  pages Page[] @relation("PageToAuthor")
  posts Post[] @relation("PostToAuthor")
  @@map("authors")
}

model Post {
  /// Primary long-form content article with lifecycle status and SEO metadata
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Author who owns and is primarily responsible for this post
  authorId String @db.Uuid @map("author_id")
  /// Article headline shown in listings and the browser tab
  title String @db.VarChar(255)
  /// URL-safe unique identifier used in the post permalink
  slug String @unique @db.VarChar(255)
  /// Full article content — supports markdown or rich-text HTML
  content String @db.Text
  /// Publication lifecycle: draft | review | published | archived
  status String @db.VarChar(20)
  /// Timestamp when the post was or will be publicly visible
  publishedAt DateTime? @db.Timestamptz(6) @map("published_at")
  /// SEO fields, open-graph image, custom schema, and reading time
  metadata Json? @db.JsonB
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  /// Record last-modified timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  comments Comment[] @relation("CommentToPost")
  author Author @relation(name: "PostToAuthor", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  revisions Draft[] @relation("RevisionToPost")
  @@index([authorId])
  @@map("posts")
}

model Draft {
  /// Immutable point-in-time snapshot of a post body for version history
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Post this revision belongs to
  postId String @db.Uuid @map("post_id")
  /// Author who saved this revision
  authorId String @db.Uuid @map("author_id")
  /// Full body snapshot at the time of saving
  content String @db.Text
  /// Monotonically increasing revision number within the post
  version String @default(1)
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  post Post @relation(name: "RevisionToPost", fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  @@map("drafts")
}

model Category {
  /// Editorial grouping for posts — supports self-referential nesting
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Parent category UUID for sub-categories (null = top-level)
  parentId String? @db.Uuid @map("parent_id")
  /// Category label shown in navigation and listings
  name String @db.VarChar(100)
  /// URL-safe unique identifier
  slug String @unique @db.VarChar(100)
  /// Short description of editorial scope for this category
  description String? @db.Text
  /// Display order among siblings
  sortOrder Int @default(0) @map("sort_order")
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  /// Record last-modified timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  parent Category? @relation(name: "CategoryToParent", fields: [parentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  children Category[] @relation("CategoryToParent")
  @@map("categories")
}

model Tag {
  /// Lightweight label applied to posts for cross-category discovery
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Tag display label
  name String @db.VarChar(80)
  /// URL-safe unique identifier
  slug String @unique @db.VarChar(80)
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  @@map("tags")
}

model Media {
  /// Uploaded file or image asset with storage metadata and accessibility info
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Author who uploaded the file
  authorId String @db.Uuid @map("author_id")
  /// Asset category: image | video | document | audio
  type String @db.VarChar(20)
  /// Public CDN or storage URL to the file
  url String @db.VarChar(500)
  /// IANA media type, e.g. image/jpeg or application/pdf
  mimeType String @db.VarChar(100) @map("mime_type")
  /// File size in bytes
  fileSize BigInt @map("file_size")
  /// Accessibility alt text for images
  altText String? @db.VarChar(255) @map("alt_text")
  /// Image dimensions, duration, codec, EXIF data
  metadata Json? @db.JsonB
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  /// Record last-modified timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  author Author @relation(name: "MediaToAuthor", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  @@map("media")
}

model Comment {
  /// Reader-submitted response on a published post — subject to moderation
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Post this comment is attached to
  postId String @db.Uuid @map("post_id")
  /// Registered author who submitted the comment (null for guests)
  authorId String? @db.Uuid @map("author_id")
  /// Display name for non-authenticated commenters
  guestName String? @db.VarChar(100) @map("guest_name")
  /// Comment content submitted by the reader
  body String @db.Text
  /// Whether the comment has passed moderation and is publicly visible
  isApproved Boolean @default(false) @map("is_approved")
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  /// Record last-modified timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  post Post @relation(name: "CommentToPost", fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  @@index([postId])
  @@map("comments")
}

model Page {
  /// Standalone static content page outside the post/category hierarchy
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Author responsible for maintaining this page
  authorId String @db.Uuid @map("author_id")
  /// Page heading shown in the browser tab and h1
  title String @db.VarChar(255)
  /// URL-safe unique path segment, e.g. about or contact
  slug String @unique @db.VarChar(255)
  /// Full page body content in markdown or HTML
  body String @db.Text
  /// Publication state: draft | published | hidden
  status String @db.VarChar(20)
  /// Whether this page appears in the main navigation menu
  showInNav Boolean @default(false) @map("show_in_nav")
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  /// Record last-modified timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  author Author @relation(name: "PageToAuthor", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  @@map("pages")
}

model Menu {
  /// Named navigation structure assigned to a location in the site theme
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Internal name used to identify this menu in the CMS
  name String @db.VarChar(100)
  /// Theme slot: header | footer | sidebar | mobile
  location String @db.VarChar(50)
  /// Whether this menu is currently rendered by the theme
  isActive Boolean @default(true) @map("is_active")
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  /// Record last-modified timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  items NavItem[] @relation("MenuItemToMenu")
  @@map("menus")
}

model NavItem {
  /// Single link or nesting node within a navigation menu
  /// Primary key — database-generated UUID
  id String @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Owning menu UUID
  menuId String @db.Uuid @map("menu_id")
  /// Parent menu item UUID for nested dropdowns (null = top-level)
  parentId String? @db.Uuid @map("parent_id")
  /// Link text displayed in the navigation
  title String @db.VarChar(100)
  /// Destination URL — absolute or site-relative path
  url String @db.VarChar(500)
  /// Whether the link opens in a new browser tab
  openInNewTab Boolean @default(false) @map("open_in_new_tab")
  /// Display order among siblings at the same nesting level
  sortOrder Int @default(0) @map("sort_order")
  /// Record creation timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  /// Record last-modified timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  menu Menu @relation(name: "MenuItemToMenu", fields: [menuId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  @@map("nav_items")
}
